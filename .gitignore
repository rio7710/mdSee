!CHANGELOG.md
!CLAUDE.md
!AGENTS.md
!doc/**/*.md
!.github/**/*.md

# Local Claude Code settings
.claude/

# Dependencies and build outputs
node_modules/
dist/

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor artifacts
.DS_Store
Thumbs.db
